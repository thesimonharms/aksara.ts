# ── Node.js ────────────────────────────────────────────────────────────────────
node_modules/
package-lock.json
npm-debug.log
yarn-error.log

# ── TypeScript build ───────────────────────────────────────────────────────────
dist/
out/
*.js.map
*.d.ts

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Project specific ───────────────────────────────────────────────────────────
src/scratchpad.ts

# ── Training — corpora & source data ───────────────────────────────────────────
# Large text dumps — obtain separately (see README)
training/jv_plain.txt
training/javanese_aksara.txt
data/jv.txt

# Root-level LM if generated outside training/
javanese_lm.pkl

# Manuscript scans
training/*.pdf
training/*.PDF

# ── Training — generated datasets (PNG strips + labels) ───────────────────────
training/ocr_data/
training/ocr_data_noisy/
training/ocr_corpus/
training/manuscript_strips/
training/pseudo_labeled/

# ── Training — intermediate outputs ───────────────────────────────────────────
# Language model (regenerated by training.sh / training.ps1)
training/javanese_lm.pkl

# PyTorch checkpoints — ONNX in model/ is the canonical inference artifact
training/*.pth
model/*.pt
model/*.pth

# Human-labeled HITL data — local only, not for distribution
training/human_labeled/

# ONNX exports land in model/ (committed); ignore any built inside training/
training/*.onnx
training/*.onnx.data

# ── Python environment ─────────────────────────────────────────────────────────
training/venv/
**/__pycache__/
*.pyc
*.pyo

# ── Fonts (binary, obtain from Google Fonts / Tuladha Jejeg project) ──────────
*.ttf
*.otf
